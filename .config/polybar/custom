color12 = ${xrdb:color12}
color13 = ${xrdb:color13}
color14 = ${xrdb:color14}
color15 = ${xrdb:color15}

[bar/black]
;monitor = ${env:MONITOR:HDMI-1}
width = 100%
height = 35 
background = ${colors.background}
foreground = ${colors.foreground}
bottom = false

line-size = 1


font-0 = JetBrainsMono Nerd Font:style=Bold:size=15;2
font-1 = Font Awesome 5 Free:style=Solid:size=14;2
font-2 = Font Awesome 5 Free:style=Regular:size=14;2
font-3 = Font Awesome 5 Brands:style=Regular:size=14;2
font-4 = Material Design Icons:style=Regular:size=16;2

wm-restack = bspwm
tray-position = right
 

modules-left = bspwm 
modules-center = xwindow
modules-right = mem  wlan  right-end-middle-two xbacklight  right-end-middle  battery  right-end-middle-twoo date powermenu 


[module/mem]
type = custom/script
exec = free -m | sed -n 's/^Mem:\s\+[0-9]\+\s\+\([0-9]\+\)\s.\+/\1/p'
format = <label>
label = ’Źø %output% 
label-padding = 1


[module/bspwm]
type = internal/bspwm

pin-workspaces = true
inline-mode = true
enable-click = true
enable-scroll = true
reverse-scroll = false

format = <label-state>

ws-icon-0 = I;%{F#c2f0fc}1
ws-icon-1 = II;%{F#fabea7}2
ws-icon-2 = III;%{F#88e1f2}3   
ws-icon-3 = IV;%{F#e36387}4      
ws-icon-4 = V;%{F#cceabb}5  
ws-icon-5 = VI;6 
ws-icon-6 = VII;%{F#c2f0fc}7    
ws-icon-7 = VIII;%{F#c2f0fc}8    
ws-icon-8 = IX;%{F#ffffff}9
ws-icon-9 = X;%{F#c2f0fc}A
ws-icon-10 = XI;%{F#fabea7}B
ws-icon-11 = XII;%{F#88e1f2}C
ws-icon-12 = XIII;%{F#e36387}D
ws-icon-13 = XIV;%{F#cceabb}E
ws-icon-14 = XV;F


label-focused = %icon%
label-focused-underline = ${colors.foreground}

label-focused-padding = 1


label-occupied = %icon%
label-occupied-foreground =#ffffff
label-occupied-padding = 1

label-empty = %icon%
label-empty-foreground =#ffffff
label-empty-padding = 1

label-urgent = %icon%
xxlabel-urgent-foreground = #88C0D0
label-urgent-padding = 1



[module/xwindow]
type = internal/xwindow
label = %title%
label-maxlen = 30
format-foreground = ${colors.foreground}
format-background = ${colors.background}
format-padding = 1

[module/xbacklight]
type = internal/xbacklight
format = <label>
format-prefix = "’üé "
format-prefix-foreground = ${colors.background}
format-prefix-background = ${colors.foreground}
label = %percentage%%
format-foreground = ${colors.background}
format-background = ${colors.foreground}
format-padding = 1


[module/date]
type = internal/date
interval = 5

time  = %H:%M
format-prefix = "’ĆŚ "
format-prefix-foreground = ${colors.color0}
format-prefix-background = ${colors.color4}
format-foreground = ${colors.color0}
format-background = ${colors.color4}
label = %time%
format-padding = 1

[module/battery]
type = internal/battery
battery = BAT1
adapter = AC0
full-at = 98

format-charging = <animation-charging> <label-charging>
label-charging = %percentage%%
format-charging-foreground = ${colors.color4}
format-charging-background = ${colors.background}

format-discharging = <ramp-capacity> <label-discharging>
label-discharging = %percentage%%
format-discharging-foreground = ${colors.foreground}
format-discharging-background = ${colors.background}

format-full-prefix = "’ĢĖ "
format-full-prefix-foreground = ${colors.color4}
format-foreground = ${colors.color4}
format-background = ${colors.background}

label-discharging-foreground = ${colors.foreground}
label-charging-foreground = ${colors.color4}
label-padding = 1

ramp-capacity-0 = ’Ģ╣
ramp-capacity-1 = ’Ģ╝
ramp-capacity-2 = ’ĢŠ
ramp-capacity-3 = ’Ģ┐
ramp-capacity-4 = ’¢ü
ramp-capacity-foreground = ${colors.foreground}

animation-charging-0 = ’¢ģ
animation-charging-1 = ’¢å
animation-charging-2 = ’¢ł
animation-charging-3 = ’¢Ŗ
animation-charging-4 = ’¢ä
animation-charging-foreground = ${colors.color4}
animation-charging-framerate = 750

format-charging-padding = 1
format-discharging-padding = 1

[module/player-moc]
type = custom/script
exec = ~/Documents/scripts/player-moc.sh
interval = 3
click-left = mocp -f &
click-right = mocp -r &
click-middle = mocp -G &

[module/coin-toss]
type = custom/script
exec = ~/Documents/scripts/toss.sh 
click-left = ~/Documents/scripts/toss.sh --toss
padding = 1

